---
import { absoluteUrl } from "../lib/seo";

const targetPath = "/en/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting to English | ConvertiLab</title>
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={absoluteUrl(targetPath)} />
    <meta http-equiv="refresh" content={`0;url=${targetPath}`} />
    <script is:inline>
      window.location.replace("/en/");
    </script>
  </head>
  <body>
    <a href={targetPath}>Continue to English site</a>
  </body>
</html>
