---
import Layout from "../../components/Layout.astro";
import { getAlternateUrls } from "../../lib/i18n/routes";
import { createBreadcrumbSchema, createWebPageSchema } from "../../lib/schema";

const routeKey = "about";
const alternateUrls = getAlternateUrls(routeKey);

const title = "About ConvertiLab";
const description =
  "Learn about ConvertiLab's approach: practical conversion tools, clear technical content, and responsible monetization.";

const structuredData = [
  createWebPageSchema({
    title,
    description,
    path: "/en/about/",
    locale: "en"
  }),
  createBreadcrumbSchema([
    { name: "Home", path: "/en/" },
    { name: "About", path: "/en/about/" }
  ])
];
---

<Layout
  locale="en"
  routeKey={routeKey}
  alternateUrls={alternateUrls}
  title={title}
  description={description}
  canonicalPath="/en/about/"
  structuredData={structuredData}
>
  <div class="container stack">
    <section class="panel">
      <h1>About ConvertiLab</h1>
      <p>
        ConvertiLab is a focused SaaS micro-service for measurement conversions used in industrial, engineering and
        logistics workflows.
      </p>
      <p>
        We prioritize speed, accuracy and useful content. Ads are integrated with strict spacing rules so they never
        block critical actions.
      </p>
      <div class="quick-links">
        <a href="/en/inches-to-millimeters/">Inches to millimeters</a>
        <a href="/en/liters-to-gallons/">Liters to gallons</a>
        <a href="/en/cubic-meters/">Cubic meters</a>
      </div>
    </section>
  </div>
</Layout>
