---
import AdSlot from "../../components/AdSlot.astro";
import Hero from "../../components/Hero.astro";
import InchesCalculator from "../../components/calculators/InchesCalculator.astro";
import Layout from "../../components/Layout.astro";
import { getAlternateUrls } from "../../lib/i18n/routes";
import {
  createBreadcrumbSchema,
  createSoftwareApplicationSchema,
  createWebPageSchema
} from "../../lib/schema";

const routeKey = "inches";
const alternateUrls = getAlternateUrls(routeKey);

const title = "Inches to millimeters converter (mm)";
const description =
  "Convert inches to millimeters using exact formulas, fraction support (1/4, 1 1/2), practical examples, and quick conversion tables.";

const structuredData = [
  createWebPageSchema({
    title,
    description,
    path: "/en/inches-to-millimeters/",
    locale: "en"
  }),
  createSoftwareApplicationSchema({
    name: "Inches to millimeters converter",
    description:
      "Free web calculator for converting inches to millimeters for engineering, maintenance and procurement.",
    path: "/en/inches-to-millimeters/",
    locale: "en"
  }),
  createBreadcrumbSchema([
    { name: "Home", path: "/en/" },
    { name: "Inches to millimeters", path: "/en/inches-to-millimeters/" }
  ])
];
---

<Layout
  locale="en"
  routeKey={routeKey}
  alternateUrls={alternateUrls}
  title={title}
  description={description}
  canonicalPath="/en/inches-to-millimeters/"
  keywords="inches to millimeters, inch to mm, fraction inch converter"
  structuredData={structuredData}
>
  <Hero
    title="Inches to millimeters converter"
    subtitle="Convert inches to mm with technical precision. Fractions like 1/4 and mixed values like 1 1/2 are supported."
    primaryCta={{ href: "#calculator", label: "Calculate now" }}
    secondaryCta={{ href: "/en/liters-to-gallons/", label: "Liters to gallons" }}
  />

  <div class="container stack">
    <section class="panel" id="calculator">
      <h2>Fast inches to mm calculator</h2>
      <p>
        Core formula: <strong>millimeters = inches x 25.4</strong>. The 25.4 factor is exact by international
        standard definition.
      </p>
      <InchesCalculator
        idPrefix="en-inches"
        eventSource="landing_inches_en"
        copyToolName="inches_mm_en"
        labels={{
          inputLabel: "Inches",
          placeholder: 'Example: 1/4, 1 1/2, 2.75',
          submitLabel: "Convert to millimeters",
          copyLabel: "Copy result",
          invalidMessage: "Enter a valid inches value. Examples: 1/4, 1 1/2, or 2.75."
        }}
      />
    </section>

    <section class="panel">
      <h2>Common examples and mistakes</h2>
      <ul class="list">
        <li>1/4 in = 6.35 mm.</li>
        <li>3/8 in = 9.525 mm.</li>
        <li>1 1/2 in = 38.1 mm.</li>
        <li>2 in = 50.8 mm.</li>
      </ul>
      <p>
        Common mistake: using 25 instead of 25.4 or rounding too early. In tight-tolerance operations this can create
        fit issues and rework.
      </p>
    </section>

    <AdSlot slotName="inches_top" note="Suggested banner position away from calculator controls." />

    <section class="panel">
      <h2>Frequent conversion table</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Inches</th>
              <th>Millimeters</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>0.125</td><td>3.175</td></tr>
            <tr><td>0.25</td><td>6.35</td></tr>
            <tr><td>0.5</td><td>12.7</td></tr>
            <tr><td>0.75</td><td>19.05</td></tr>
            <tr><td>1</td><td>25.4</td></tr>
            <tr><td>2</td><td>50.8</td></tr>
            <tr><td>4</td><td>101.6</td></tr>
            <tr><td>8</td><td>203.2</td></tr>
          </tbody>
        </table>
      </div>
      <p>
        Related tools:
        <a href="/en/liters-to-gallons/"> liters to gallons</a> and
        <a href="/en/cubic-meters/"> cubic meters</a>.
      </p>
    </section>

    <AdSlot slotName="inches_bottom" note="Final monetization slot without blocking usability." />
  </div>
</Layout>
