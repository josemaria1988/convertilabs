---
import Layout from "../../components/Layout.astro";
import { getAlternateUrls } from "../../lib/i18n/routes";
import { createBreadcrumbSchema, createWebPageSchema } from "../../lib/schema";

const routeKey = "contact";
const alternateUrls = getAlternateUrls(routeKey);

const title = "Contact";
const description =
  "Contact ConvertiLab to report conversion issues, suggest new tools, or discuss commercial partnerships.";

const structuredData = [
  createWebPageSchema({
    title,
    description,
    path: "/en/contact/",
    locale: "en"
  }),
  createBreadcrumbSchema([
    { name: "Home", path: "/en/" },
    { name: "Contact", path: "/en/contact/" }
  ])
];
---

<Layout
  locale="en"
  routeKey={routeKey}
  alternateUrls={alternateUrls}
  title={title}
  description={description}
  canonicalPath="/en/contact/"
  structuredData={structuredData}
>
  <div class="container stack">
    <section class="panel">
      <h1>Contact</h1>
      <p>
        To report formula issues or propose new conversion tools, write to
        <a href="mailto:hola@convertilab.com"> hola@convertilab.com</a>.
      </p>
      <p>Estimated response time: 24 to 72 business hours.</p>
    </section>
  </div>
</Layout>
