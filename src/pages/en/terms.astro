---
import Layout from "../../components/Layout.astro";
import { getAlternateUrls } from "../../lib/i18n/routes";
import { createBreadcrumbSchema, createWebPageSchema } from "../../lib/schema";

const routeKey = "terms";
const alternateUrls = getAlternateUrls(routeKey);

const title = "Terms and conditions";
const description =
  "ConvertiLab terms for using conversion calculators, liability limits, and service update policies.";

const structuredData = [
  createWebPageSchema({
    title,
    description,
    path: "/en/terms/",
    locale: "en"
  }),
  createBreadcrumbSchema([
    { name: "Home", path: "/en/" },
    { name: "Terms", path: "/en/terms/" }
  ])
];
---

<Layout
  locale="en"
  routeKey={routeKey}
  alternateUrls={alternateUrls}
  title={title}
  description={description}
  canonicalPath="/en/terms/"
  structuredData={structuredData}
>
  <div class="container stack">
    <section class="panel">
      <h1>Terms and conditions</h1>
      <p>
        By using ConvertiLab, you accept these terms. Calculators are provided with technical care, but users are
        responsible for validating outputs in regulated or critical scenarios.
      </p>
      <p>
        Abusive automated usage that harms site performance is prohibited. We may update features and legal texts to
        maintain service quality and security.
      </p>
      <p>Last update: March 4, 2026.</p>
    </section>
  </div>
</Layout>
