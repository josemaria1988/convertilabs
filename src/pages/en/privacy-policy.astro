---
import Layout from "../../components/Layout.astro";
import { getAlternateUrls } from "../../lib/i18n/routes";
import { createBreadcrumbSchema, createWebPageSchema } from "../../lib/schema";

const routeKey = "privacy";
const alternateUrls = getAlternateUrls(routeKey);

const title = "Privacy policy";
const description =
  "ConvertiLab privacy policy covering analytics, advertising, and handling of browsing data.";

const structuredData = [
  createWebPageSchema({
    title,
    description,
    path: "/en/privacy-policy/",
    locale: "en"
  }),
  createBreadcrumbSchema([
    { name: "Home", path: "/en/" },
    { name: "Privacy policy", path: "/en/privacy-policy/" }
  ])
];
---

<Layout
  locale="en"
  routeKey={routeKey}
  alternateUrls={alternateUrls}
  title={title}
  description={description}
  canonicalPath="/en/privacy-policy/"
  structuredData={structuredData}
>
  <div class="container stack">
    <section class="panel">
      <h1>Privacy policy</h1>
      <p>
        ConvertiLab processes minimal browsing data to measure performance, improve product quality, and operate
        advertising responsibly.
      </p>
      <ul class="list">
        <li>Cloudflare Web Analytics for anonymous traffic metrics.</li>
        <li>Optional GA4 for product event tracking.</li>
        <li>Optional AdSense for monetization.</li>
      </ul>
      <p>Last update: March 4, 2026.</p>
    </section>
  </div>
</Layout>
