---
import Layout from "../../components/Layout.astro";
import { getAlternateUrls } from "../../lib/i18n/routes";
import { createBreadcrumbSchema, createWebPageSchema } from "../../lib/schema";

const routeKey = "contact";
const alternateUrls = getAlternateUrls(routeKey);

const title = "Contacto";
const description =
  "Contacto de ConvertiLab para reportar errores de conversion, mejoras de contenido o consultas comerciales.";

const structuredData = [
  createWebPageSchema({
    title,
    description,
    path: "/es/contacto/",
    locale: "es"
  }),
  createBreadcrumbSchema([
    { name: "Inicio", path: "/es/" },
    { name: "Contacto", path: "/es/contacto/" }
  ])
];
---

<Layout
  locale="es"
  routeKey={routeKey}
  alternateUrls={alternateUrls}
  title={title}
  description={description}
  canonicalPath="/es/contacto/"
  structuredData={structuredData}
>
  <div class="container stack">
    <section class="panel">
      <h1>Contacto</h1>
      <p>
        Si detectas un error de formula o quieres proponer una nueva herramienta, puedes escribirnos a:
        <a href="mailto:hola@convertilab.com"> hola@convertilab.com</a>.
      </p>
      <p>Tiempo de respuesta estimado: 24 a 72 horas habiles.</p>
    </section>
  </div>
</Layout>
