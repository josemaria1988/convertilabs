---
import AdSlot from "../../components/AdSlot.astro";
import Hero from "../../components/Hero.astro";
import InchesCalculator from "../../components/calculators/InchesCalculator.astro";
import Layout from "../../components/Layout.astro";
import { getAlternateUrls } from "../../lib/i18n/routes";
import {
  createBreadcrumbSchema,
  createSoftwareApplicationSchema,
  createWebPageSchema
} from "../../lib/schema";

const routeKey = "inches";
const alternateUrls = getAlternateUrls(routeKey);

const title = "Conversor de pulgadas a milimetros (mm) online";
const description =
  "Convierte pulgadas a milimetros con formula exacta, fracciones tipo 1/4, tabla de conversion y casos reales de taller y logistica.";

const structuredData = [
  createWebPageSchema({
    title,
    description,
    path: "/es/pulgadas-a-milimetros/",
    locale: "es"
  }),
  createSoftwareApplicationSchema({
    name: "Conversor de pulgadas a milimetros",
    description:
      "Herramienta web gratuita para convertir pulgadas a milimetros en mantenimiento, mecanizado y compras tecnicas.",
    path: "/es/pulgadas-a-milimetros/",
    locale: "es"
  }),
  createBreadcrumbSchema([
    { name: "Inicio", path: "/es/" },
    { name: "Pulgadas a milimetros", path: "/es/pulgadas-a-milimetros/" }
  ])
];
---

<Layout
  locale="es"
  routeKey={routeKey}
  alternateUrls={alternateUrls}
  title={title}
  description={description}
  canonicalPath="/es/pulgadas-a-milimetros/"
  keywords="pulgadas a milimetros, inches to mm, conversion fracciones pulgadas"
  structuredData={structuredData}
>
  <Hero
    title="Conversor de pulgadas a milimetros"
    subtitle="Pasa de pulgadas a mm con precision tecnica. Acepta fracciones como 1/4, 3/8 y valores mixtos como 1 1/2."
    primaryCta={{ href: "#calculadora", label: "Calcular ahora" }}
    secondaryCta={{ href: "/es/litros-a-galones/", label: "Litros a galones" }}
  />

  <div class="container stack">
    <section class="panel" id="calculadora">
      <h2>Calculadora rapida de pulgadas a mm</h2>
      <p>
        Formula base: <strong>milimetros = pulgadas x 25.4</strong>. Es un factor exacto por estandar internacional.
      </p>
      <InchesCalculator
        idPrefix="es-inches"
        eventSource="landing_inches_es"
        copyToolName="inches_mm_es"
        labels={{
          inputLabel: "Pulgadas",
          placeholder: 'Ej: 1/4, 1 1/2, 2.75',
          submitLabel: "Convertir a milimetros",
          copyLabel: "Copiar resultado",
          invalidMessage: "Ingresa pulgadas validas. Ejemplos: 1/4, 1 1/2 o 2.75."
        }}
      />
    </section>

    <section class="panel">
      <h2>Ejemplos reales y errores comunes</h2>
      <ul class="list">
        <li>1/4 in = 6.35 mm.</li>
        <li>3/8 in = 9.525 mm.</li>
        <li>1 1/2 in = 38.1 mm.</li>
        <li>2 in = 50.8 mm.</li>
      </ul>
      <p>
        Error habitual: usar 25 en lugar de 25.4 o redondear antes de terminar el calculo. En piezas con tolerancias
        ajustadas, esas diferencias pueden generar retrabajo.
      </p>
    </section>

    <AdSlot slotName="inches_top" note="Ubicacion sugerida de banner, separada de la calculadora." />

    <section class="panel">
      <h2>Tabla de conversiones frecuentes</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Pulgadas</th>
              <th>Milimetros</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>0.125</td><td>3.175</td></tr>
            <tr><td>0.25</td><td>6.35</td></tr>
            <tr><td>0.5</td><td>12.7</td></tr>
            <tr><td>0.75</td><td>19.05</td></tr>
            <tr><td>1</td><td>25.4</td></tr>
            <tr><td>2</td><td>50.8</td></tr>
            <tr><td>4</td><td>101.6</td></tr>
            <tr><td>8</td><td>203.2</td></tr>
          </tbody>
        </table>
      </div>
      <p>
        Enlaces utiles:
        <a href="/es/litros-a-galones/"> litros a galones</a> y
        <a href="/es/metros-cubicos/"> metros cubicos</a>.
      </p>
    </section>

    <AdSlot slotName="inches_bottom" note="Bloque final de monetizacion no invasiva." />
  </div>
</Layout>
