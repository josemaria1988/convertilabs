---
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_TITLE,
  absoluteUrl,
  buildTitle
} from "../lib/seo";
import type { AlternateUrl, Locale } from "../lib/i18n/types";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  keywords?: string;
  noindex?: boolean;
  structuredData?: Array<Record<string, unknown>>;
  locale?: Locale;
  alternateUrls?: AlternateUrl[];
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonicalPath,
  keywords,
  noindex = false,
  structuredData = [],
  locale,
  alternateUrls = []
} = Astro.props;

const finalTitle = buildTitle(title ?? DEFAULT_TITLE);
const canonical = canonicalPath ? absoluteUrl(canonicalPath) : undefined;
---

<title>{finalTitle}</title>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
{keywords && <meta name="keywords" content={keywords} />}
{canonical && <link rel="canonical" href={canonical} />}

<meta property="og:type" content="website" />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={description} />
{canonical && <meta property="og:url" content={canonical} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={description} />
{locale && <meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />}
{
  alternateUrls.map((alternate) => (
    <link rel="alternate" hreflang={alternate.locale} href={absoluteUrl(alternate.path)} />
  ))
}

{
  structuredData.map((item) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
  ))
}
