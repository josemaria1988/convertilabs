APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
DATABASE_URL=postgres://postgres.your-project-ref:your-password@aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
DIRECT_URL=postgres://postgres.your-project-ref:your-password@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
OPENAI_API_KEY=your-openai-api-key
OPENAI_PRIMARY_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini
OPENAI_USE_MINI_BY_DEFAULT=false
OPENAI_DOCUMENT_MODEL=
OPENAI_RULES_MODEL=
OPENAI_ACCOUNTING_MODEL=
OPENAI_HTTP_MAX_RETRIES=2
OPENAI_HTTP_RETRY_DELAY_MS=250
OPENAI_USAGE_COST_INPUT_USD_PER_1M=
OPENAI_USAGE_COST_OUTPUT_USD_PER_1M=
# Zetasoftware REST base URL. Convertilabs agrega /APIs/<EndpointName>.
ZETASOFTWARE_BASE_URL=https://api.zetasoftware.com/rest

# Credenciales del integrador. Son de Convertilabs, no del cliente.
ZETASOFTWARE_DESARROLLADOR_CODIGO=your-developer-code
ZETASOFTWARE_DESARROLLADOR_CLAVE=your-developer-secret

# Clave AES-256-GCM para credenciales de organizaciones en DB.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=

# Fallback de desarrollo para una organizacion. En produccion se prefieren
# credenciales cifradas en organization_integration_connections.
ZETASOFTWARE_EMPRESA_CODIGO=your-company-code
ZETASOFTWARE_EMPRESA_CLAVE=your-company-secret
ZETASOFTWARE_USUARIOCODIGO=1
ZETASOFTWARE_ROLCODIGO=1

# Perfil opcional para desarrollo multi-org sin DB.
# Con env_profile=RONTIL, el runtime lee primero ZETASOFTWARE_RONTIL_*.
# ZETASOFTWARE_RONTIL_EMPRESA_CODIGO=
# ZETASOFTWARE_RONTIL_EMPRESA_CLAVE=
# ZETASOFTWARE_RONTIL_USUARIOCODIGO=1
# ZETASOFTWARE_RONTIL_ROLCODIGO=1
INNGEST_DEV=1
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
INNGEST_BASE_URL=
VAT_UY_MVP_ENABLED=true
VAT_UY_EXPORT_AUTO_DISABLED=true
VAT_UY_MIXED_USE_MANUAL_REVIEW=true
VAT_UY_SIMPLIFIED_REGIME_AUTO_DISABLED=true
